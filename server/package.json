{
  "name": "pravko-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch index.ts",
    "dev:worker": "tsx watch worker/transcodeWorker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker/transcodeWorker.js",
    "migrate": "tsx db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@fastify/cors": "^11.0.0",
    "bullmq": "^5.40.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.3.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.6.0",
    "jose": "^6.0.0",
    "nodemailer": "^6.9.0",
    "pg": "^8.14.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  }
}
